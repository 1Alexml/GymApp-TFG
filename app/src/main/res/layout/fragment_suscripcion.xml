<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/fondo_oscuro"
        android:padding="20dp">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:indeterminateTint="@color/verde_activo" />

        <!-- Sin suscripciones -->
        <LinearLayout
            android:id="@+id/layout_sin_sus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="40sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin suscripciones activas"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/blanco"
                android:gravity="center"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Lista de suscripciones (todas, con gimnasio) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_suscripciones"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clipToPadding="false" />

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
